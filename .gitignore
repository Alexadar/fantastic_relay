# macOS
.DS_Store
**/.DS_Store

# Editor / tooling
.idea/
*.swp
.claude/

# Scratch (gitignored by request)
tmp/

# Swift (Package.resolved IS committed for reproducible builds)
.build/
**/.build/
.swiftpm/
DerivedData/
*.xcodeproj

# Container build staging (assembled by container/build.sh)
**/container/.ctx/

# Python (integration_tests) — venv + caches; uv.lock IS committed
**/.venv/
__pycache__/
*.pyc
.pytest_cache/

# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Tunnel credentials (cloudflared)
*.cloudflared/
cert.pem
*.tunnel.json
