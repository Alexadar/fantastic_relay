# macOS
.DS_Store
**/.DS_Store

# Editor / tooling
.idea/
*.swp
.claude/

# Scratch (gitignored by request)
tmp/

# Swift (Package.resolved IS committed for reproducible builds)
.build/
**/.build/
.swiftpm/
DerivedData/
*.xcodeproj

# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Tunnel credentials (cloudflared)
*.cloudflared/
cert.pem
*.tunnel.json
